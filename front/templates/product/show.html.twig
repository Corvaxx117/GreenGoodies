{% extends 'base.html.twig' %}

{% block title %}{{ product.name }} | GreenGoodies{% endblock %}

{% block body %}
    <section class="product-page">
        <div class="product-page__media">
            <img src="{{ asset(product.imagePath) }}" alt="{{ product.name }}" width="740" height="740" loading="eager" fetchpriority="high">
        </div>

        <div class="product-page__content">
            <p class="section-heading__label">{{ product.brand }}</p>
            <h1 class="product-page__title">{{ product.name }}</h1>
            <p class="product-page__price">
                {% if product.priceCents is divisible by(100) %}
                    {{ (product.priceCents / 100)|number_format(0, ',', ' ') }}€
                {% else %}
                    {{ (product.priceCents / 100)|number_format(2, ',', ' ') }}€
                {% endif %}
            </p>

            <div class="product-page__description">
                <p class="product-page__label">Description</p>
                {% for paragraph in product.description|split('\n\n') %}
                    <p>{{ paragraph }}</p>
                {% endfor %}
            </div>

            {% if app.user %}
                <form class="product-page__purchase-form" method="post" action="{{ path('front_cart_item_upsert', { slug: product.slug }) }}">
                    <div class="product-page__quantity-row">
                        <label class="product-page__label" for="product-quantity">Quantité</label>
                        <input id="product-quantity" class="product-page__quantity" type="number" name="quantity" min="0" value="{{ currentQuantity > 0 ? currentQuantity : 1 }}">
                    </div>

                    <input type="hidden" name="_token" value="{{ csrf_token('front_cart_item_' ~ product.slug) }}">

                    <button class="product-page__cta" type="submit">
                        {{ currentQuantity > 0 ? 'Mettre à jour' : 'Ajouter au panier' }}
                    </button>
                </form>
            {% else %}
                <a class="product-page__cta product-page__cta--link" href="{{ path('front_login') }}">Se connecter pour commander</a>
            {% endif %}
        </div>
    </section>
{% endblock %}
